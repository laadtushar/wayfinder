{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo view:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet build:*)",
      "Bash(adb devices:*)",
      "Bash(adb install:*)",
      "Bash(adb logcat:*)",
      "Bash(gdalinfo:*)",
      "Bash(gdalwarp:*)",
      "Bash(gdal_translate:*)",
      "Bash(brew list:*)",
      "Bash(ls:*)",
      "Bash(uvx:*)",
      "Read",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/.env)",
      "Read(./**/*.pem)",
      "Read(./**/secrets/**)",
      "Read(./**/*serviceAccount*.json)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)"
    ]
  }
}
