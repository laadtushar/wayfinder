{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/block-meta-unity-edit.ps1"
          }
        ]
      },
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/warn-csharp-hotpath.ps1"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo view:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet build:*)",
      "Bash(adb devices:*)",
      "Bash(adb install:*)",
      "Bash(adb logcat:*)",
      "Bash(gdalinfo:*)",
      "Bash(gdalwarp:*)",
      "Bash(gdal_translate:*)",
      "Bash(brew list:*)",
      "Bash(ls:*)",
      "Bash(uvx:*)",
      "Read",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/.env)",
      "Read(./**/*.pem)",
      "Read(./**/secrets/**)",
      "Read(./**/*serviceAccount*.json)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)"
    ]
  }
}