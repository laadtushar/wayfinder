# OS
.DS_Store

# Large raw source data (keep processing recipes in docs/, not the multi-GB rasters)
data/raw/

# APK / player build output at the repo root (device-deploy artifacts)
/Builds/

# --- Unity (applies once the unity/ project is added) ---
unity/[Ll]ibrary/
unity/[Tt]emp/
unity/[Oo]bj/
unity/[Bb]uild/
unity/[Bb]uilds/
unity/.utmp/
unity/[Ll]ogs/
unity/[Uu]ser[Ss]ettings/
unity/[Mm]emoryCaptures/
unity/*.apk
unity/*.aab

# .NET build output (core/ staging projects)
core/**/bin/
core/**/obj/

# Unity batchmode logs at repo root
unity-*.log

# graphify knowledge-graph output (regenerable; cache is per-machine)
graphify-out/

# Unity-MCP execute_code Roslyn support DLLs (machine-local editor tooling,
# must never ship in a player build — marked Editor-only via PluginImporter)
unity/Assets/Plugins/Roslyn/

# Unity crash-recovery scene backups
unity/Assets/_Recovery/

# Headless bake logs
bake*.log

# Scratch verification captures (frame grabs from the MCP bridge)
captures/
